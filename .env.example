# ─── MOA-to-HIF Evidence Prioritization Agent — Environment Variables ─────────────────────

# LLM Backend Selection
# Options: auto | gemini | ollama | meditron
# auto = smart routing: IO/checkpoint drugs → Gemini, others → Ollama
LLM_BACKEND=auto

# Google Gemini API key (required for Gemini backend)
GEMINI_API_KEY=

# Ollama local LLM server (default: localhost)
OLLAMA_BASE_URL=http://localhost:11434

# NCBI API key (optional — increases PubMed rate limits)
NCBI_API_KEY=

# Directory for diskcache (default: ./digital_pathology/.cache/digpath)
CACHE_DIR=

# Cache TTL in seconds (default: 604800 = 7 days)
CACHE_TTL=604800

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
